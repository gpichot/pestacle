  "compilerOptions": {
    "module": "ESNext",
    "lib": ["ES2020"],
    "target": "ES2020",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noUnusedLocals": true,
    "noFallthroughCasesInSwitch": true,
    "useUnknownInCatchVariables": true,
